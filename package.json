{
  "name": "@shipsilently/node",
  "version": "0.1.0",
  "description": "ShipSilently feature flag SDK for Node.js and universal JavaScript/TypeScript",
  "author": "ShipSilently",
  "homepage": "https://shipsilently.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipsilently/node.git"
  },
  "bugs": {
    "url": "https://github.com/shipsilently/node/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["feature-flags", "cloudflare", "shipsilently", "node"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
